{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "http://localhost:5174",
          "http://127.0.0.1:5173",
          "http://127.0.0.1:5174",
          "https://admin.vikashtechsolution.com",
          "https://lms.vikashtechsolution.com",
          "https://course.vikashtechsolution.com"
