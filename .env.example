PORT=5001
MONGO_URI=mongodb://localhost:27017/online-course

JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRE=7d
JWT_RESET_EXPIRE=15m

# Resend (email service)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Set to "true" to use local storage instead of R2 (for dev or when R2 has issues)
USE_LOCAL_UPLOADS=false

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=online-course
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Lecture video → HLS (optional tuning)
# Parallel segment uploads to R2 (default 8). Raise on fast uplink / large batches.
# HLS_R2_UPLOAD_CONCURRENCY=8
# FFmpeg preset when re-encoding is required: veryfast | faster | fast | medium (slower, smaller files)
# FFMPEG_PRESET=veryfast

# Super Admin (used by seed script)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@vts.com
SUPER_ADMIN_PASSWORD=admin123

# Frontend URLs (for CORS and email links)
ADMIN_FRONTEND_URL=http://localhost:5174
STUDENT_FRONTEND_URL=http://localhost:5173

# Base URL for avatar/file URLs (optional; defaults to request origin)
API_BASE_URL=http://localhost:5001

# API CORS (see server.js corsOptions):
# - Leave empty: allow any origin (reflects Origin; works with credentials).
# - CORS_ORIGINS=*  or  CORS_ORIGINS=all  — same as empty (explicit "allow all").
# - CORS_ORIGINS=https://a.com,https://b.com — allowlist only.
CORS_ORIGINS=
